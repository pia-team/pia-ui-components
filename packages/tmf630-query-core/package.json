{
  "name": "@pia-team/pia-ui-tmf630-query-core",
  "version": "0.5.0",
  "description": "TMF630 QueryDSL core — framework-agnostic types, operators, serialization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./search-config.schema.json": "./search-config.schema.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "search-config.schema.json"
  ],
  "keywords": ["tmf630", "querydsl", "filter", "serialize"],
  "license": "MIT"
}
